# Supabase Configuration
# Get these values from your Supabase project dashboard at https://app.supabase.com
# Go to Settings > API to find your project URL and API keys

# Your Supabase project URL (required)
# Example: https://xyzcompany.supabase.co
VITE_SUPABASE_URL=https://jwvcnbtbjyqntxdwzgqc.supabase.co

# Your Supabase anonymous/public key (required)
# This is safe to use in client-side code
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp3dmNuYnRianlxbnR4ZHd6Z3FjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTg5MDM2MjAsImV4cCI6MjA3NDQ3OTYyMH0.hvi3poohBOMTaknS0p-C3mgwa_s4zex6Y_Vj_alnFyA

# Your Supabase service role key (SERVER-SIDE ONLY, for admin operations)
# ⚠️ CRITICAL WARNING: Never expose this key in client-side code!
# ⚠️ Do NOT prefix with VITE_ - that exposes it to the browser!
# Only use this in server-side code or secure environments
# Rotate any exposed keys immediately in your Supabase dashboard
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database Configuration (for local development and CLI operations)
# Database password for local Supabase instance
VITE_SUPABASE_DB_PASSWORD=postgres

# Project ID for CLI operations (not prefixed with VITE_ as it's server-side)
SUPABASE_PROJECT_ID=your_project_id_here

# Direct database connection URL for migrations (server-side only)
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Storage Configuration
# Storage API URL (usually derived from project URL)
VITE_SUPABASE_STORAGE_URL=https://jwvcnbtbjyqntxdwzgqc.supabase.co/storage/v1

# Maximum file size for uploads (in bytes) - 10MB default
VITE_MAX_FILE_SIZE=10485760

# Comma-separated list of allowed file extensions
VITE_ALLOWED_FILE_TYPES=jpg,jpeg,png,webp,gif

# Application Configuration
# The URL where your application is hosted (for redirects and email links)
# For development: http://localhost:5173
# For production: https://yourapp.com
VITE_APP_URL=http://localhost:5173

# Development Configuration
# Enable/disable real-time subscriptions for development
VITE_ENABLE_REALTIME=true

# Enable database query logging for debugging
VITE_DEBUG_DATABASE=false

# Optional: Environment identifier
VITE_APP_ENV=development

# Local Development Notes:
# - For local development, use 'supabase start' to run Supabase locally
# - Local Supabase URL will be http://localhost:54321
# - Local anon key can be found in supabase/config.toml after 'supabase init'
# - Use 'npm run db:types' to generate TypeScript types from your schema